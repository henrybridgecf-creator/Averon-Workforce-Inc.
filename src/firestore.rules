
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the requesting user is an admin.
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper function to check if the user is the owner of the document.
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users can read and update their own profile.
    // Admins can read and write to any user profile.
    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      allow create, delete: if isAdmin(); // Only admins can create/delete user records directly
    }

    // Only admins can read the list of other admins.
    // Creation/deletion should be handled server-side or by a super admin.
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Prevent clients from writing to the admins collection
    }

    // Admins can create, read, update, and delete any project.
    // Assigned users can read and update (for submission) their own projects.
    match /projects/{projectId} {
      allow read, write: if isAdmin();
      allow read, update: if resource.data.assignedTo == request.auth.uid;
    }

    // Users can create and read their own withdrawal requests.
    // Admins can read all requests and update their status.
    match /withdrawals/{withdrawalId} {
      allow read, update: if isAdmin();
      allow create: if isOwner(request.resource.data.userId);
      allow read: if isOwner(resource.data.userId);
    }
    
    // Allow read/write access to a chat document if the user is a participant or an admin.
    match /chats/{chatId} {
      allow read, write: if request.auth.uid in resource.data.participants || isAdmin();
    }

    // Users can read messages in a chat they are a participant of. Admins can read any message.
    // Users can only create messages. Admins can manage all messages.
    match /chats/{chatId}/messages/{messageId} {
       allow read, create: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin();
       allow update, delete: if isAdmin();
    }
  }
}
